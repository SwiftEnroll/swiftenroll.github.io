# SwiftEnroll Site Environment Variables
# Copy this file to .env and customize for your local environment

# Form endpoints - leave empty to disable form submissions in local development
# HUGO_PARAMS_FORMS_CONTACTENDPOINT=""
# HUGO_PARAMS_FORMS_DEMOENDPOINT=""
# HUGO_PARAMS_FORMS_SUBSCRIBEENDPOINT=""

# Production endpoints (default values from hugo.toml)
# HUGO_PARAMS_FORMS_CONTACTENDPOINT="https://submit-form.com/9cR1q3cWi"
# HUGO_PARAMS_FORMS_DEMOENDPOINT="https://submit-form.com/InyGZDbvs"
# HUGO_PARAMS_FORMS_SUBSCRIBEENDPOINT="https://submit-form.com/subscribe"

# Cloudflare Turnstile site key (optional override)
# HUGO_PARAMS_FORMS_TURNSTILESITEKEY="0x4AAAAAAB--JQpodZqe67sc"

# Honeypot field name (optional override)
# HUGO_PARAMS_FORMS_HONEYPOTFIELDNAME="_gotcha"
