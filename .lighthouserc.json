{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "url": [
        "http://localhost/index.html",
        "http://localhost/features/index.html",
        "http://localhost/pricing/index.html",
        "http://localhost/demo/index.html",
        "http://localhost/contact/index.html",
        "http://localhost/industries/youth-sports-fitness/index.html",
        "http://localhost/company/index.html"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.9}],
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "categories:best-practices": ["error", {"minScore": 0.9}],
        "categories:seo": ["error", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
