{
  "name": "hugo-saasify-demo",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npx tailwindcss -i assets/css/main.css -o static/css/style.css --watch\" \"dotenv -- hugo server -D\"",
    "build": "tailwindcss -i assets/css/main.css -o static/css/style.css --minify && hugo --minify"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.4.19"
  }
}
